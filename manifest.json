{
  "manifest_version": 3,
  "name": "Canvas Calendar Sync",
  "version": "1.0",
  "description": "Automatically sync Canvas assignments to Google Calendar",
  "permissions": [
    "identity",
    "storage"
  ],
  "host_permissions": [
    "*://*.instructure.com/*",
    "https://www.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "740190741545-p8o861ef4alffj7ceio4669lcuf517c7.apps.googleusercontent.com", 
    "scopes": [
      "https://www.googleapis.com/auth/calendar",
      "https://www.googleapis.com/auth/tasks"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon16.png"
      
      
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon16.png"
    
    
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["*://*.instructure.com/*"],
      "js": ["content.js"]
    }
  ]
}

